<%- include('partials/header')%>

<div class="container mt=5">
        <h1>login</h1>

        <div class="row">
            <div class="col-sm-8">
                <div class="card">
                    <div class="card-body">

                        
                        <form action="/login" method="POST">
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" class="form-control" name="username" id="email" required>
                            </div><br>

                            <div class="form-group">
                                <label for="password">Password</label>
                                <input type="password" id="password" class="form-control" placeholder="Enter Password" required><br>
                                <button type="button" onclick="togglePassword()">Show Password</button>
                            </div><br>

                                    
                                    <button type="submit" class="btn btn-dark">Login</button>
                                    

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>